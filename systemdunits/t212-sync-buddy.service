[Unit]
Description=Trading212 → Ghostfolio daily import
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=YOUR_USER
WorkingDirectory=/path/to/T212-Sync-buddy
ExecStart=/path/to/T212-Sync-buddy/venv/bin/python3 t212_fetch.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
